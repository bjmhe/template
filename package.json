{
  "name": "@bjmhe/template",
  "version": "0.0.2",
  "description": "A template for creating a TypeScript package.",
  "author": "Benjamin He <hi@bjmhe.me>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bjmhe/template.git"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "repository": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "autofix": "run-s autofix:*",
    "autofix:automd": "automd",
    "autofix:bjmhe": "bjmhe fetch",
    "autofix:check": "vp check --fix",
    "build": "vp pack",
    "dev": "vp pack --watch",
    "prepublishOnly": "vp run build",
    "release": "bumpp"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.3",
    "@bjmhe/automd": "^0.0.7",
    "@bjmhe/bjmhe": "^1.0.2",
    "@bjmhe/viteplus-preset": "^2.0.3",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^25.9.1",
    "@typescript/native-preview": "7.0.0-dev.20260603.1",
    "@vitest/coverage-v8": "^4.1.8",
    "bumpp": "^11.1.0",
    "npm-run-all": "^4.1.5",
    "publint": "^0.3.21",
    "tsnapi": "^0.3.3",
    "typescript": "^6.0.3",
    "unplugin-unused": "^0.5.7",
    "vite-plus": "^0.1.24"
  },
  "engines": {
    "node": ">=24.16.0"
  },
  "packageManager": "pnpm@11.4.0"
}
