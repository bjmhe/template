    "prepublishOnly": "pnpm run build",
    "release": "bumpp",
    "typecheck": "tsgo --noEmit"
  },
  "devDependencies": {
    "@sxzz/eslint-config": "8.1.0",
    "@types/node": "25.7.0",
    "@typescript/native-preview": "7.0.0-dev.20260512.1",
    "bumpp": "11.1.0",
    "eslint": "10.3.0",
    "prettier": "3.8.3",
    "tsdown": "0.22.0",
    "tsdown-preset-sxzz": "0.6.0"
  },
  "packageManager": "pnpm@11.0.9",
  "publishConfig": {
    "access": "public"
  }
}